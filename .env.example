# متغيرات البيئة — انسخ الملف إلى .env وعدّل القيم
# على Render: تُضبط تلقائياً من render.yaml

PORT=4700
DB_PATH=./db/cafe_pos.db

# ---- واتساب (اختياري) ----
# لتفعيل إرسال أكواد التفعيل وإشعارات الطلبات فعلياً على الواتساب،
# احصل على حساب WhatsApp Business API من Meta واملأ القيمتين.
# بدونهما يعمل النظام في "الوضع التجريبي" (يعرض الكود على الشاشة).
WA_TOKEN=
WA_PHONE_ID=
